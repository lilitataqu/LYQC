package com.ueit.running.mapper;

import com.ueit.running.domain.RunInfo;
import com.ueit.running.domain.vo.RunInfoDataVo;

import java.util.List;

public interface RunInfoDataMapper {


    /**
     * 查询跑步信息
     *
     * @param id 跑步信息主键
     * @return 跑步信息
     */
    public RunInfoDataVo selectRunInfoById(Long id);

    /**
     * 查询跑步信息列表
     *
     * @param runInfo 跑步信息
     * @return 跑步信息集合
     */
    public List<RunInfoDataVo> selectRunInfoList(RunInfo runInfo);
}
