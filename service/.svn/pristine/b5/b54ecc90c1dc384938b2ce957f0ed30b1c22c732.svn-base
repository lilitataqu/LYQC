<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ueit.running.mapper.RunInfoDataMapper">

    <resultMap type="RunInfoDataVo" id="RunInfoDataResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="studentId"    column="student_id"    />
<!--        <result property="userName"    column="user_name"    />-->
        <result property="nickName"    column="nick_name"    />
<!--        <result property="userDeptname"    column="user_deptname"    />-->
        <result property="deptName"    column="dept_name"    />
        <result property="time"    column="time"    />
        <result property="speed"    column="speed"    />
        <result property="kcal"    column="kcal"    />
        <result property="distance"    column="distance"    />
        <result property="kmSpeed"    column="km_speed"    />
        <result property="points"    column="points"    />
        <result property="altitude"    column="altitude"    />
        <result property="altitudeSum"    column="altitude_sum"    />
        <result property="runType"    column="run_type"    />
        <result property="step"    column="step"    />
        <result property="state"    column="state"    />
        <result property="delState"    column="del_state"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>


    <select id="selectRunInfoList" parameterType="RunInfoListDto" resultMap="RunInfoDataResult">
        select r.id, u.student_id, u.nick_name,d.dept_name, r.user_id, r.time, r.speed, r.kcal, r.distance, r.km_speed, r.altitude, r.altitude_sum, r.run_type, r.state, r.del_state, r.create_by, r.create_time, r.update_by, r.update_time
        from run_info r
        join  sys_user u ON r.user_id=u.user_id
        join  sys_dept d ON u.dept_id=d.dept_id
        <where>
            <if test="nickName != null and nickName != ''"> and nick_name like concat('%', #{nickName}, '%')</if>
            <if test="studentId != null and studentId != ''"> and student_id like concat('%', #{studentId}, '%')</if>
            <if test="state != null and state != ''"> and state = #{state}</if>
            <if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
                AND date_format(r.create_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
                AND date_format(r.create_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
            <if test="isTeacher">
                r.user_id IN ( SELECT cu.user_id FROM tb_class_hour c JOIN tb_class_hour_user cu ON c.id = cu.class_id
                <where>
                    and c.semester = #{semester}
                    <if test="classId != null and classId != ''">
                        and c.id = #{classId}
                    </if>
                    <if test="teacherUserId != null and teacherUserId != ''">
                        and c.user_id = #{teacherUserId}
                    </if>
                </where>
                )
            </if>
            and del_state = 0
        </where>
        order by id desc
    </select>

    <select id="selectRunInfoListSum" parameterType="RunInfoListDto" resultType="map">
        select
            count( DISTINCT ( r.user_id ) ) AS user,
            count( r.id ) AS count,
            ifnull(( sum( r.distance ) / 1000 ), 0) AS distance,
            ifnull(( sum( r.kcal ) / 1000 ), 0) AS kcal,
            count( r.state = 0 OR NULL ) AS conformCount
        from run_info r
            join  sys_user u ON r.user_id=u.user_id
            join  sys_dept d ON u.dept_id=d.dept_id
        <where>
            <if test="nickName != null and nickName != ''"> and nick_name like concat('%', #{nickName}, '%')</if>
            <if test="studentId != null and studentId != ''"> and student_id like concat('%', #{studentId}, '%')</if>
            <if test="state != null and state != ''"> and state = #{state}</if>
            <if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
                AND date_format(r.create_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
                AND date_format(r.create_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
            and del_state = 0
        </where>
        order by id desc
    </select>



</mapper>