<template>
  <div class="app-container">
    <el-form :model="queryParams" ref="queryForm" size="small" :inline="true" v-show="showSearch" label-width="68px">
      <el-form-item label="用户表id" prop="userId">
        <el-input
          v-model="queryParams.userId"
          placeholder="请输入用户表id"
          clearable
          @keyup.enter.native="handleQuery"
        />
      </el-form-item>
      <el-form-item label="微信用户openid" prop="wxOpenid">
        <el-input
          v-model="queryParams.wxOpenid"
          placeholder="请输入微信用户openid"
          clearable
          @keyup.enter.native="handleQuery"
        />
      </el-form-item>
      <el-form-item label="用户在开放平台的唯一标识符" prop="unionid">
        <el-input
          v-model="queryParams.unionid"
          placeholder="请输入用户在开放平台的唯一标识符"
          clearable
          @keyup.enter.native="handleQuery"
        />
      </el-form-item>
      <el-form-item label="体重Kg" prop="weight">
        <el-input
          v-model="queryParams.weight"
          placeholder="请输入体重Kg"
          clearable
          @keyup.enter.native="handleQuery"
        />
      </el-form-item>
      <el-form-item label="身高cm" prop="height">
        <el-input
          v-model="queryParams.height"
          placeholder="请输入身高cm"
          clearable
          @keyup.enter.native="handleQuery"
        />
      </el-form-item>
      <el-form-item label="路程目标" prop="distance">
        <el-input
          v-model="queryParams.distance"
          placeholder="请输入路程目标"
          clearable
          @keyup.enter.native="handleQuery"
        />
      </el-form-item>
      <el-form-item label="卡路里目标" prop="kcal">
        <el-input
          v-model="queryParams.kcal"
          placeholder="请输入卡路里目标"
          clearable
          @keyup.enter.native="handleQuery"
        />
      </el-form-item>
      <el-form-item label="${comment}" prop="str1s">
        <el-input
          v-model="queryParams.str1s"
          placeholder="请输入${comment}"
          clearable
          @keyup.enter.native="handleQuery"
        />
      </el-form-item>
      <el-form-item label="${comment}" prop="str2s">
        <el-input
          v-model="queryParams.str2s"
          placeholder="请输入${comment}"
          clearable
          @keyup.enter.native="handleQuery"
        />
      </el-form-item>
      <el-form-item label="${comment}" prop="int1i">
        <el-input
          v-model="queryParams.int1i"
          placeholder="请输入${comment}"
          clearable
          @keyup.enter.native="handleQuery"
        />
      </el-form-item>
      <el-form-item label="${comment}" prop="int2i">
        <el-input
          v-model="queryParams.int2i"
          placeholder="请输入${comment}"
          clearable
          @keyup.enter.native="handleQuery"
        />
      </el-form-item>
      <el-form-item>
        <el-button type="primary" icon="el-icon-search" size="mini" @click="handleQuery">搜索</el-button>
        <el-button icon="el-icon-refresh" size="mini" @click="resetQuery">重置</el-button>
      </el-form-item>
    </el-form>

    <el-row :gutter="10" class="mb8">
      <el-col :span="1.5">
        <el-button
          type="primary"
          plain
          icon="el-icon-plus"
          size="mini"
          @click="handleAdd"
          v-hasPermi="['running:wechat:add']"
        >新增</el-button>
      </el-col>
      <el-col :span="1.5">
        <el-button
          type="success"
          plain
          icon="el-icon-edit"
          size="mini"
          :disabled="single"
          @click="handleUpdate"
          v-hasPermi="['running:wechat:edit']"
        >修改</el-button>
      </el-col>
      <el-col :span="1.5">
        <el-button
          type="danger"
          plain
          icon="el-icon-delete"
          size="mini"
          :disabled="multiple"
          @click="handleDelete"
          v-hasPermi="['running:wechat:remove']"
        >删除</el-button>
      </el-col>
      <el-col :span="1.5">
        <el-button
          type="warning"
          plain
          icon="el-icon-download"
          size="mini"
          @click="handleExport"
          v-hasPermi="['running:wechat:export']"
        >导出</el-button>
      </el-col>
      <right-toolbar :showSearch.sync="showSearch" @queryTable="getList"></right-toolbar>
    </el-row>

    <el-table v-loading="loading" :data="wechatList" @selection-change="handleSelectionChange">
      <el-table-column type="selection" width="55" align="center" />
      <el-table-column label="ID" align="center" prop="id" />
      <el-table-column label="用户表id" align="center" prop="userId" />
      <el-table-column label="微信用户openid" align="center" prop="wxOpenid" />
      <el-table-column label="用户在开放平台的唯一标识符" align="center" prop="unionid" />
      <el-table-column label="体重Kg" align="center" prop="weight" />
      <el-table-column label="身高cm" align="center" prop="height" />
      <el-table-column label="路程目标" align="center" prop="distance" />
      <el-table-column label="卡路里目标" align="center" prop="kcal" />
      <el-table-column label="性别" align="center" prop="sex" />
      <el-table-column label="${comment}" align="center" prop="str1s" />
      <el-table-column label="${comment}" align="center" prop="str2s" />
      <el-table-column label="${comment}" align="center" prop="int1i" />
      <el-table-column label="${comment}" align="center" prop="int2i" />
      <el-table-column label="操作" align="center" class-name="small-padding fixed-width">
        <template slot-scope="scope">
          <el-button
            size="mini"
            type="text"
            icon="el-icon-edit"
            @click="handleUpdate(scope.row)"
            v-hasPermi="['running:wechat:edit']"
          >修改</el-button>
          <el-button
            size="mini"
            type="text"
            icon="el-icon-delete"
            @click="handleDelete(scope.row)"
            v-hasPermi="['running:wechat:remove']"
          >删除</el-button>
        </template>
      </el-table-column>
    </el-table>

    <pagination
      v-show="total>0"
      :total="total"
      :page.sync="queryParams.pageNum"
      :limit.sync="queryParams.pageSize"
      @pagination="getList"
    />

    <!-- 添加或修改系统用户与微信用户关联对话框 -->
    <el-dialog :title="title" :visible.sync="open" width="500px" append-to-body>
      <el-form ref="form" :model="form" :rules="rules" label-width="80px">
        <el-form-item label="用户表id" prop="userId">
          <el-input v-model="form.userId" placeholder="请输入用户表id" />
        </el-form-item>
        <el-form-item label="微信用户openid" prop="wxOpenid">
          <el-input v-model="form.wxOpenid" placeholder="请输入微信用户openid" />
        </el-form-item>
        <el-form-item label="用户在开放平台的唯一标识符" prop="unionid">
          <el-input v-model="form.unionid" placeholder="请输入用户在开放平台的唯一标识符" />
        </el-form-item>
        <el-form-item label="体重Kg" prop="weight">
          <el-input v-model="form.weight" placeholder="请输入体重Kg" />
        </el-form-item>
        <el-form-item label="身高cm" prop="height">
          <el-input v-model="form.height" placeholder="请输入身高cm" />
        </el-form-item>
        <el-form-item label="路程目标" prop="distance">
          <el-input v-model="form.distance" placeholder="请输入路程目标" />
        </el-form-item>
        <el-form-item label="卡路里目标" prop="kcal">
          <el-input v-model="form.kcal" placeholder="请输入卡路里目标" />
        </el-form-item>
        <el-form-item label="${comment}" prop="str1s">
          <el-input v-model="form.str1s" placeholder="请输入${comment}" />
        </el-form-item>
        <el-form-item label="${comment}" prop="str2s">
          <el-input v-model="form.str2s" placeholder="请输入${comment}" />
        </el-form-item>
        <el-form-item label="${comment}" prop="int1i">
          <el-input v-model="form.int1i" placeholder="请输入${comment}" />
        </el-form-item>
        <el-form-item label="${comment}" prop="int2i">
          <el-input v-model="form.int2i" placeholder="请输入${comment}" />
        </el-form-item>
      </el-form>
      <div slot="footer" class="dialog-footer">
        <el-button type="primary" @click="submitForm">确 定</el-button>
        <el-button @click="cancel">取 消</el-button>
      </div>
    </el-dialog>
  </div>
</template>

<script>
  import { listWechat, getWechat, delWechat, addWechat, updateWechat } from "@/api/running/wechat";

  export default {
    name: "Wechat",
    data() {
      return {
        // 遮罩层
        loading: true,
        // 选中数组
        ids: [],
        // 非单个禁用
        single: true,
        // 非多个禁用
        multiple: true,
        // 显示搜索条件
        showSearch: true,
        // 总条数
        total: 0,
        // 系统用户与微信用户关联表格数据
        wechatList: [],
        // 弹出层标题
        title: "",
        // 是否显示弹出层
        open: false,
        // 查询参数
        queryParams: {
          pageNum: 1,
          pageSize: 10,
          userId: null,
          wxOpenid: null,
          unionid: null,
          weight: null,
          height: null,
          distance: null,
          kcal: null,
          sex: null,
          str1s: null,
          str2s: null,
          int1i: null,
          int2i: null
        },
        // 表单参数
        form: {},
        // 表单校验
        rules: {
        }
      };
    },
    created() {
      this.getList();
    },
    methods: {
      /** 查询系统用户与微信用户关联列表 */
      getList() {
        this.loading = true;
        listWechat(this.queryParams).then(response => {
          this.wechatList = response.rows;
          this.total = response.total;
          this.loading = false;
        });
      },
      // 取消按钮
      cancel() {
        this.open = false;
        this.reset();
      },
      // 表单重置
      reset() {
        this.form = {
          id: null,
          userId: null,
          wxOpenid: null,
          unionid: null,
          weight: null,
          height: null,
          distance: null,
          kcal: null,
          sex: null,
          createBy: null,
          createTime: null,
          updateBy: null,
          updateTime: null,
          str1s: null,
          str2s: null,
          int1i: null,
          int2i: null
        };
        this.resetForm("form");
      },
      /** 搜索按钮操作 */
      handleQuery() {
        this.queryParams.pageNum = 1;
        this.getList();
      },
      /** 重置按钮操作 */
      resetQuery() {
        this.resetForm("queryForm");
        this.handleQuery();
      },
      // 多选框选中数据
      handleSelectionChange(selection) {
        this.ids = selection.map(item => item.id)
        this.single = selection.length!==1
        this.multiple = !selection.length
      },
      /** 新增按钮操作 */
      handleAdd() {
        this.reset();
        this.open = true;
        this.title = "添加系统用户与微信用户关联";
      },
      /** 修改按钮操作 */
      handleUpdate(row) {
        this.reset();
        const id = row.id || this.ids
        getWechat(id).then(response => {
          this.form = response.data;
          this.open = true;
          this.title = "修改系统用户与微信用户关联";
        });
      },
      /** 提交按钮 */
      submitForm() {
        this.$refs["form"].validate(valid => {
          if (valid) {
            if (this.form.id != null) {
              updateWechat(this.form).then(response => {
                this.$modal.msgSuccess("修改成功");
                this.open = false;
                this.getList();
              });
            } else {
              addWechat(this.form).then(response => {
                this.$modal.msgSuccess("新增成功");
                this.open = false;
                this.getList();
              });
            }
          }
        });
      },
      /** 删除按钮操作 */
      handleDelete(row) {
        const ids = row.id || this.ids;
        this.$modal.confirm('是否确认删除系统用户与微信用户关联编号为"' + ids + '"的数据项？').then(function() {
          return delWechat(ids);
        }).then(() => {
          this.getList();
          this.$modal.msgSuccess("删除成功");
        }).catch(() => {});
      },
      /** 导出按钮操作 */
      handleExport() {
        this.download('running/wechat/export', {
          ...this.queryParams
        }, `wechat_${new Date().getTime()}.xlsx`)
      }
    }
  };
</script>
