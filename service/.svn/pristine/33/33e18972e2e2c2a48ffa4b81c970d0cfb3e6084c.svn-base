import request from '@/utils/request'

// 查询本周各学员运动量列表
export function listUserWeekStatistic(query) {
    return request({
        url: '/running/userWeekStatistic/list',
        method: 'get',
        params: query
    })
}

// 用户选择列表
export function userList() {
    return request({
        url: '/running/userWeekStatistic/userList',
        method: 'get',
    })
}

