<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ueit.running.mapper.TournamentGroupUserMapper">

    <resultMap type="TournamentGroupUser" id="TournamentGroupUserResult">
