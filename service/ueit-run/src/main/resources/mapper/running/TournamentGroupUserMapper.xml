        <result property="delState" column="del_state"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <resultMap type="TournamentMyVo" id="TournamentMyVoResult">
        <result property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="groupName" column="group_name"/>
        <result property="distance" column="distance"/>
        <result property="updateTime" column="update_time"/>
        <result property="time" column="time"/>
    </resultMap>

    <resultMap type="TournamentRankVo" id="TournamentRankVoResult">
        <result property="nickName" column="nick_name"/>
        <result property="avataer" column="avataer"/>
        <result property="count" column="count"/>
        <result property="sumTime" column="sumTime"/>
        <result property="avgTime" column="avgTime"/>
    </resultMap>

    <resultMap type="TournamentRankSystemVo" id="TournamentRankSystemVoResult">
        <result property="num" column="num"/>
        <result property="phonenumber" column="phonenumber"/>
        <result property="nickName" column="nick_name"/>
        <result property="avataer" column="avataer"/>
        <result property="count" column="count"/>
        <result property="sumTime" column="sumTime"/>
        <result property="avgTime" column="avgTime"/>
    </resultMap>

    <sql id="selectTournamentGroupUserVo">
        select id, tournament_group_id, user_id, time, speed, kcal, distance, km_speed, points, altitude, altitude_sum, run_type, step, state, del_state, create_by, create_time, update_by, update_time
        from tb_tournament_group_user
    </sql>

    <select id="selectTournamentGroupUserList" parameterType="TournamentGroupUser"
            resultMap="TournamentGroupUserResult">
        <include refid="selectTournamentGroupUserVo"/>
        <where>
            <if test="tournamentGroupId != null ">
                and tournament_group_id = #{tournamentGroupId}
            </if>
            <if test="userId != null ">
                and user_id = #{userId}
            </if>
            <if test="state != null ">
                and state = #{state}
            </if>
            <if test="delState != null ">
                and del_state = #{delState}
            </if>
        </where>
    </select>

    <select id="selectTournamentGroupUserById" parameterType="Long"
            resultMap="TournamentGroupUserResult">
        <include refid="selectTournamentGroupUserVo"/>
        where id = #{id}
    </select>

    <select id="selectTournamentUserByTournamentId" resultMap="TournamentGroupUserResult">
        SELECT
            tu.tournament_group_id, tu.time, tu.update_time
        FROM
            tb_tournament_group_user tu
            INNER JOIN tb_tournament_group tg ON tu.tournament_group_id = tg.id
        WHERE
            tg.tournament_id = #{tournamentId}
            AND tu.user_id = #{userId}
            and tu.del_state = 0
            <if test="state != null ">
                and state = #{state}
            </if>
        ORDER BY tu.id desc
    </select>

    <select id="selectMyTournamentRecord" parameterType="Long" resultMap="TournamentMyVoResult">
        SELECT
            tu.id,
            t.`name`,
            t.cover,
            tg.`name` as group_name,
            tg.distance,
            tu.update_time,
            tu.time
        FROM
            tb_tournament_group_user tu
            INNER JOIN tb_tournament_group tg ON tg.id = tu.tournament_group_id
            INNER JOIN tb_tournament t ON t.id = tg.tournament_id
        WHERE
            tu.user_id = #{userId}
            and tu.state = 0
        ORDER BY
	        update_time DESC
    </select>

    <select id="selectTournamentRank" parameterType="Long" resultMap="TournamentRankVoResult">
        SELECT
            u.nick_name,
            u.avatar,
            count( * ) AS count,
            SEC_TO_TIME( sum( TIME_TO_SEC( tu.time ) ) ) AS sumTime,
            SEC_TO_TIME( AVG( TIME_TO_SEC( tu.time ) ) ) AS avgTime
        FROM
            tb_tournament_group_user tu
            INNER JOIN tb_tournament_group tg ON ( tu.tournament_group_id = tg.id AND tu.state = 0 )
            INNER JOIN tb_tournament t ON t.id = tg.tournament_id
            INNER JOIN sys_user u ON u.user_id = tu.user_id
        WHERE
            tu.tournament_group_id = #{groupId}
        GROUP BY
            u.user_id
        ORDER BY
            count DESC, sumTime ASC
    </select>

    <select id="selectTournamentRankSystem" parameterType="TournamentRankSystemDto" resultMap="TournamentRankSystemVoResult">
        SELECT
        ( @i := @i + 1 ) AS num,
        a.*
        FROM
        (
        SELECT
        u.nick_name,
        u.phonenumber,
        u.avatar,
        count( * ) AS count,
        SEC_TO_TIME( sum( TIME_TO_SEC( tu.time ) ) ) AS sumTime,
        SEC_TO_TIME( AVG( TIME_TO_SEC( tu.time ) ) ) AS avgTime
        FROM
        tb_tournament_group_user tu
        INNER JOIN tb_tournament_group tg ON ( tu.tournament_group_id = tg.id AND tu.state = 0 )
        INNER JOIN tb_tournament t ON t.id = tg.tournament_id
        INNER JOIN sys_user u ON u.user_id = tu.user_id
        WHERE
        tu.tournament_group_id = #{groupId}
        GROUP BY
        u.user_id
        <if test="maxNumber != null">
            HAVING count >= #{maxNumber}
        </if>
        ORDER BY
        count DESC,
        sumTime ASC
        ) a,(SELECT @i:=0) d
    </select>

