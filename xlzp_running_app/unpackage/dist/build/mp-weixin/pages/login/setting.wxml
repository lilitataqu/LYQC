<view><block wx:if="{{steps=='1'}}"><view><view><view class="text-center padding-sm margin-top"><text class="text-grey text-xl">欢迎使用小程序</text></view><view class="text-center"><text class="text-grey text-sm">完善您的信息让我们为您提供更精准的服务</text></view><view class="text-center margin-top-xl"><text class="text-grey text-lg">请问您的性别是?</text></view><view class="flex margin-top-md padding justify-center"><block wx:if="{{sex}}"><button class="cu-btn bg-blue margin-left margin-right round lg" data-sex="{{true}}" data-event-opts="{{[['tap',[['changeSex',['$event']]]]]}}" bindtap="__e">男</button></block><block wx:if="{{!sex}}"><button class="cu-btn line-blue margin-left margin-right round lg" data-sex="{{true}}" data-event-opts="{{[['tap',[['changeSex',['$event']]]]]}}" bindtap="__e">男</button></block><block wx:if="{{!sex}}"><button class="cu-btn bg-red margin-left margin-right round lg" data-sex="{{false}}" data-event-opts="{{[['tap',[['changeSex',['$event']]]]]}}" bindtap="__e">女</button></block><block wx:if="{{sex}}"><button class="cu-btn line-red margin-left margin-right round lg" data-sex="{{false}}" data-event-opts="{{[['tap',[['changeSex',['$event']]]]]}}" bindtap="__e">女</button></block></view></view><view class="text-center padding margin-top"><button class="cu-btn bg-grey round lg" data-steps="2" data-event-opts="{{[['tap',[['next',['$event']]]]]}}" bindtap="__e">下一步</button></view><view class="text-center padding margin-top"><text class="text-grey text-lg">性别的不同,将会影响卡路里计算的准确性哦。</text></view></view></block><block wx:if="{{steps=='2'}}"><view><view><view class="text-center margin-top-xl"><text class="text-grey text-lg">请问您的身高和体重是?</text></view><view class="flex margin-top-md padding justify-center bg"><form><view class="cu-form-group margin-top" style="width:300px;"><view class="title">身高</view><picker value="{{height_index}}" range="{{height_picker}}" data-event-opts="{{[['change',[['heightSetting',['$event']]]]]}}" bindchange="__e"><view class="picker">{{height_picker[height_index]+" Cm"}}</view></picker></view><view class="cu-form-group margin-top"><view class="title">体重</view><picker value="{{weight_index}}" range="{{weight_picker}}" data-event-opts="{{[['change',[['weightSetting',['$event']]]]]}}" bindchange="__e"><view class="picker">{{weight_picker[weight_index]+" Kg"}}</view></picker></view></form></view></view><view class="text-center padding margin-top"><button class="cu-btn bg-grey margin-left margin-right round lg" data-steps="1" data-event-opts="{{[['tap',[['next',['$event']]]]]}}" bindtap="__e">上一步</button><button class="cu-btn bg-grey margin-left margin-right round lg" data-steps="3" data-event-opts="{{[['tap',[['next',['$event']]]]]}}" bindtap="__e">下一步</button></view><view class="text-center padding margin-top"><text class="text-grey text-lg">身高体重的不同,将会影响卡路里和运动里程,运动配速的计算准确性哦。</text></view></view></block><block wx:if="{{steps=='3'}}"><view><view><view class="text-center margin-top-xl"><text class="text-grey text-lg">请输入您的姓名与学号:</text></view><view class="flex margin-top-md padding justify-center bg"><form><view class="cu-form-group margin-top" style="width:300px;"><view class="title">姓名</view><input class="uni-input text-right" maxlength="10" placeholder="限制10个字符" data-event-opts="{{[['input',[['__set_model',['','name','$event',[]]]]]]}}" value="{{name}}" bindinput="__e"/></view><view class="cu-form-group margin-top"><view class="title">学号</view><input class="uni-input text-right" maxlength="30" placeholder="限制30个字符" data-event-opts="{{[['input',[['__set_model',['','studentId','$event',[]]]]]]}}" value="{{studentId}}" bindinput="__e"/></view><view class="cu-form-group margin-top"><view class="title">学校</view><uni-data-picker vue-id="b255afb6-1" localdata="{{schoolList}}" popup-title="请选择学校" map="{{({text:'deptName',value:'deptId'})}}" clear-icon="{{false}}" border="{{false}}" data-event-opts="{{[['^change',[['schoolListChange']]]]}}" bind:change="__e" bind:__l="__l"></uni-data-picker></view><view hidden="{{!(showBranchCourts)}}" class="cu-form-group margin-top"><view class="title">学院</view><uni-data-picker class="vue-ref" vue-id="b255afb6-2" localdata="{{branchCourtsList}}" popup-title="请选择学院" map="{{({text:'deptName',value:'deptId'})}}" clear-icon="{{false}}" border="{{false}}" data-ref="branchCourtsChoose" data-event-opts="{{[['^change',[['branchCourtsListChange']]],['^popupopened',[['branchCourtOpen']]]]}}" bind:change="__e" bind:popupopened="__e" bind:__l="__l"></uni-data-picker></view></form></view><view class="text-center padding margin-top"><text class="text-grey text-lg">请准确输入，将会影响成绩统计。</text></view></view><view class="text-center padding margin-top"><button class="cu-btn bg-grey margin-left margin-right round lg" data-steps="2" data-event-opts="{{[['tap',[['next',['$event']]]]]}}" bindtap="__e">上一步</button><button class="cu-btn bg-grey margin-left margin-right round lg" data-steps="4" data-event-opts="{{[['tap',[['next',['$event']]]]]}}" bindtap="__e">完成</button></view></view></block></view>