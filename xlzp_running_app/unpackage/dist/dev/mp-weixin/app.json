      },
      {
        "pagePath": "pages/game/game",
        "text": "比赛",
        "selectedIconPath": "/static/icon/game.png",
        "iconPath": "static/icon/game_sub.png"
      },
      {
        "pagePath": "pages/me/index",
        "text": "我",
        "selectedIconPath": "/static/icon/person-2.png",
