<view><z-paging class="vue-ref" bind:query="__e" bind:input="__e" vue-id="74ad0258-1" data-ref="paging" value="{{dataList}}" data-event-opts="{{[['^query',[['getList']]],['^input',[['__set_model',['','dataList','$event',[]]]]]]}}" bind:__l="__l" vue-slots="{{['default']}}"><block wx:for="{{dataList}}" wx:for-item="item" wx:for-index="index"><view><view class="cu-card article no-card margin-top" data-id="{{item.id}}" data-event-opts="{{[['tap',[['toDetail',['$event']]]]]}}" bindtap="__e"><view class="cu-item shadow"><view class="title"><view class="text-cut"><text class="cuIcon-titles text-cyan"></text>{{''+item.createTime+''}}</view></view><view class="content"><block wx:if="{{item.runType==0}}"><image style="height:5.4em;" src="/static/icon/run-sub.png" mode="aspectFit"></image></block><block wx:else><image style="height:5.4em;" src="/static/icon/indoor.png" mode="aspectFit"></image></block><view class="desc"><view class="text-content"><text>{{"运动里程:"+item.distance/1000+" Km"}}</text></view><view><block wx:if="{{item.state==0}}"><view class="cu-tag bg-green light sm round">已达标</view></block><block wx:if="{{item.state==1}}"><view class="cu-tag bg-red light sm round">距离未达标</view></block><block wx:if="{{item.state==2}}"><view class="cu-tag bg-red light sm round">配速未达标</view></block><block wx:if="{{item.state==3}}"><view class="cu-tag bg-red light sm round">时间未达标</view></block><block wx:if="{{item.state==4}}"><view class="cu-tag bg-gray light sm round">及格</view></block><block wx:if="{{item.state==5}}"><view class="cu-tag bg-yellow light sm round">良好</view></block><block wx:if="{{item.state==6}}"><view class="cu-tag bg-green light sm round">优秀</view></block></view><view><view class="cu-tag bg-green light sm round">{{item.time}}</view><view class="cu-tag bg-orange light sm round">{{item.speed}}</view><view class="cu-tag bg-red light sm round">{{item.kcal/1000+" Kcal"}}</view></view></view></view></view></view></view></block></z-paging></view>